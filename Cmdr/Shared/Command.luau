local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local Argument = require(script.Parent.Argument)

local IsServer = RunService:IsServer()

--[=[
	@class CommandContext
	Represents an individual command execution, encapsulating state, arguments, and routing across the client-server boundary.
]=]

local Command = {}
Command.__index = Command

--[=[
	@prop Dispatcher Dispatcher
	@within CommandContext
	@readonly
	The dispatcher instance that created this command context.
]=]

--[=[
	@prop Cmdr Cmdr | CmdrClient
	@within CommandContext
	@readonly
	A direct reference to Cmdr. This may either be the server or client version depending on where the command is running.
]=]

--[=[
	@prop Name string
	@within CommandContext
	@readonly
	The primary name of the command being executed (not its alias).
]=]

--[=[
	@prop RawText string
	@within CommandContext
	@readonly
	The complete, unparsed raw text sequence used to trigger this command.
]=]

--[=[
	@prop Object CommandDefinition
	@within CommandContext
	@readonly
	The complete underlying static command definition layout configuration.
]=]

--[=[
	@prop Group any
	@within CommandContext
	@readonly
	The group category assigned to this command, typically a string.
]=]

--[=[
	@prop State table
	@within CommandContext
	A blank dictionary useful for carrying user-defined execution state across hooks or internal pipeline filters.
]=]

--[=[
	@prop Aliases {string}
	@within CommandContext
	@readonly
	An array of secondary matching aliases capable of evoking this command.
]=]

--[=[
	@prop Alias string
	@within CommandContext
	@readonly
	The specific identifier string utilized by the user to invoke this execution context.
]=]

--[=[
	@prop Description string
	@within CommandContext
	@readonly
	The display description explaining what the command does.
]=]

--[=[
	@prop Executor Player
	@within CommandContext
	@readonly
	The native Roblox `Player` instance that executed this command text string.
]=]

--[=[
	@prop ArgumentDefinitions {ArgumentDefinition}
	@within CommandContext
	@readonly
	The structural argument schema arrays inherited from the command definition layout.
]=]

--[=[
	@prop RawArguments {string}
	@within CommandContext
	@readonly
	An array of split string inputs mapped before evaluation and validation phases occur.
]=]

--[=[
	@prop Arguments {ArgumentContext}
	@within CommandContext
	@readonly
	An array matching internal parsed `ArgumentContext` values tied sequentially to inputs.
]=]

--[=[
	@prop Data any
	@within CommandContext
	Special contextual data object fetched client-side and routed down into server pipelines.
]=]

--[=[
	@prop Response string?
	@within CommandContext
	@readonly
	The returned execution or error feedback output string context generated by run parameters.
]=]

--[=[
	@prop Guards { (CommandContext) -> string? }
	@within CommandContext
	@readonly
	A table of guarding interception hooks capable of short-circuiting runtime sequences.
]=]

--[=[
	Constructs a unique operational command context tracking record.
	@param options table -- Parameters mapping layout specifications to state fields.
	@return CommandContext
	@private
	@within CommandContext
]=]
function Command.new(options)
	local self = {
		Dispatcher = options.Dispatcher,
		Cmdr = options.Dispatcher.Cmdr,
		Name = options.CommandObject.Name,
		RawText = options.Text,
		Object = options.CommandObject,
		Group = options.CommandObject.Group,
		State = {},
		Aliases = options.CommandObject.Aliases,
		Alias = options.Alias,
		Description = options.CommandObject.Description,
		Executor = options.Executor,
		ArgumentDefinitions = options.CommandObject.Args,
		RawArguments = options.Arguments,
		Arguments = {},
		Data = options.Data,
		Response = nil,
		Guards = options.Guards,
	}

	setmetatable(self, Command)

	return self
end

--[=[
	Parses unparsed raw text segments into structural `ArgumentContext` blocks.

	@param allowIncompleteArguments boolean? -- If true, suppresses missing parameter exceptions during multi-step updates.
	@return boolean -- Returns true if arguments successfully constructed.
	@return string? -- Error description if validation breaks structural order conventions.
	@private
	@within CommandContext
]=]
function Command:Parse(allowIncompleteArguments)
	local hadOptional = false
	for i, definition in ipairs(self.ArgumentDefinitions) do
		if type(definition) == "function" then
			definition = definition(self)

			if definition == nil then
				break
			end
		end

		local required = (definition.Default == nil and definition.Optional ~= true)

		if required and hadOptional then
			error(("[Cmdr] Command %q: Required arguments cannot occur after optional arguments."):format(self.Name))
		elseif not required then
			hadOptional = true
		end

		if self.RawArguments[i] == nil and required and allowIncompleteArguments ~= true then
			return false, ("Required argument #%d %s is missing."):format(i, definition.Name)
		elseif self.RawArguments[i] or allowIncompleteArguments then
			self.Arguments[i] = Argument.new(self, definition, self.RawArguments[i] or "")
		end
	end

	return true
end

--[=[
	Validates every argument against its structural type constraints. Must be successfully processed prior to executing `:Run()`.

	@param isFinal boolean -- Indicates whether the user has fully committed the line by hitting Enter.
	@return boolean -- True if all argument checks pass layout requirements.
	@return string -- Concatenated validation failure messages.
	@private
	@within CommandContext
]=]
function Command:Validate(isFinal)
	self._Validated = true
	local errorText = ""
	local success = true

	for i, arg in pairs(self.Arguments) do
		local argSuccess, argErrorText = arg:Validate(isFinal)

		if not argSuccess then
			success = false
			errorText = ("%s; #%d %s: %s"):format(errorText, i, arg.Name, argErrorText or "error")
		end
	end

	return success, errorText:sub(3)
end

--[=[
	Scans contextual entries in reverse to locate the last argument containing text. Mainly useful for updating current autocompletion layouts.

	@return ArgumentContext?
	@within CommandContext
]=]
function Command:GetLastArgument()
	for i = #self.Arguments, 1, -1 do
		if self.Arguments[i].RawValue then
			return self.Arguments[i]
		end
	end
end

--[=[
	Gathers fully resolved evaluation values across every registered parameter.

	@return {any} -- An array containing parsed native values or fallback defaults.
	@return number -- Total number of expected parameter arguments.
	@private
	@within CommandContext
]=]
function Command:GatherArgumentValues()
	local values = {}

	for i = 1, #self.ArgumentDefinitions do
		local arg = self.Arguments[i]
		if arg then
			values[i] = arg:GetValue()
		elseif type(self.ArgumentDefinitions[i]) == "table" then
			values[i] = self.ArgumentDefinitions[i].Default
		end
	end

	return values, #self.ArgumentDefinitions
end

--[=[
	Triggers execution pipelines for hooks, layout guards, and boundary evaluation modules.

	@return string? -- The final logged text response result.
	@within CommandContext
]=]
function Command:Run()
	if self._Validated == nil then
		error("[Cmdr] Must validate a command before running.")
	end

	local beforeRunHook = self.Dispatcher:RunHooks("BeforeRun", self)
	if beforeRunHook then
		return beforeRunHook
	end

	local guardMethods = self.Dispatcher:RunGuards(self)
	if guardMethods then
		return guardMethods
	end

	if not IsServer and self.Object.Data and self.Data == nil then
		local values, length = self:GatherArgumentValues()
		self.Data = self.Object.Data(self, unpack(values, 1, length))
	end

	if not IsServer and self.Object.ClientRun then
		local values, length = self:GatherArgumentValues()
		self.Response = self.Object.ClientRun(self, unpack(values, 1, length))
	end

	if self.Response == nil then
		if self.Object.Run then -- We can just Run it here on this machine
			local values, length = self:GatherArgumentValues()
			self.Response = self.Object.Run(self, unpack(values, 1, length))
		elseif IsServer then -- Uh oh, we're already on the server and there's no Run function.
			if self.Object.ClientRun then
				warn(
					`[Cmdr] {self.Name} command fell back to the server because ClientRun returned nil, but there is no server implementation! Either return a string from ClientRun, or create a server implementation for this command.`
				)
			else
				warn(`[Cmdr] {self.Name} command has no implementation!`)
			end

			self.Response = "No implementation."
		else -- We're on the client, so we send this off to the server to let the server see what it can do with it.
			self.Response = self.Dispatcher:Send(self.RawText, self.Data)
		end
	end

	local afterRunHook = self.Dispatcher:RunHooks("AfterRun", self)
	if afterRunHook then
		return afterRunHook
	else
		return self.Response
	end
end

--[=[
	Returns the `ArgumentContext` object for the given index.

	@param index number -- The positional index of the argument.
	@return ArgumentContext?
	@within CommandContext
]=]
function Command:GetArgument(index)
	return self.Arguments[index]
end

-- Below are functions that are only meant to be used in command implementations --

--[=[
	Returns the custom gathered data payload mapped by client-side definition closures.

	@return any
	@within CommandContext
]=]
function Command:GetData()
	if self.Data then
		return self.Data
	end

	if self.Object.Data and not IsServer then
		self.Data = self.Object.Data(self)
	end

	return self.Data
end

--[=[
	Dispatches a named network event targeting a specific player (on the server), or processes a local handler event sequence directly (on the client).

	@param player Player -- Target user instance.
	@param event string -- The unique identifier string name of the network event.
	@param ... any -- Extensible arguments passed alongside the payload.
	@within CommandContext
]=]
function Command:SendEvent(player, event, ...)
	assert(typeof(player) == "Instance" and player:IsA("Player"), "[Cmdr] Argument #1 must be a Player")
	assert(type(event) == "string", "[Cmdr] Argument #2 must be a string")

	if IsServer then
		self.Dispatcher.Cmdr.RemoteEvent:FireClient(player, event, ...)
	elseif self.Dispatcher.Cmdr.Events[event] then
		assert(
			player == Players.LocalPlayer,
			"[Cmdr] Event messages can only be sent to the local player on the client."
		)
		self.Dispatcher.Cmdr.Events[event](...)
	end
end

--[=[
	Broadcasts a custom network event message sequentially targeting all connected clients.

	@param event string -- The registration name of the network event.
	@param ... any -- Dynamic arguments bundled within the packet.
	@within CommandContext
]=]
function Command:BroadcastEvent(event, ...)
	if not IsServer then
		error("[Cmdr] Can't broadcast event messages from the client.", 2)
	end

	self.Dispatcher.Cmdr.RemoteEvent:FireAllClients(event, ...)
end

--[=[
	Prints text inside the invoking executor's console UI frame window. Useful for streaming verbose text output lines over progressive asynchronous jobs.

	@param text string -- The output line text statement to print.
	@param options (Color3 | { Color: Color3?, RichText: boolean? })? -- Optional coloring configurations or a settings dictionary containing `Color` and `RichText` formatting flags.
	@within CommandContext
]=]
function Command:Reply(text, options)
	return self:SendEvent(self.Executor, "AddLine", text, options)
end

--[=[
	Queries persistent global data storage structures registered under a tracking name.

	@param name string -- Identifiable keyword reference mapping out the store.
	@return table
	@within CommandContext
]=]
function Command:GetStore(name)
	return self.Dispatcher.Cmdr.Registry:GetStore(name)
end

--[=[
	Returns true if the core executable logic of this context has a runnable implementation on the machine currently handling evaluations.

	@return boolean
	@within CommandContext
]=]
function Command:HasImplementation()
	return ((RunService:IsClient() and self.Object.ClientRun) or self.Object.Run) and true or false
end

return Command
